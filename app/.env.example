# Server
PORT=3000
APP_BASE_URL=http://localhost:3000

# MySQL (use either DATABASE_URL or host-based config)
# DATABASE_URL format: mysql://user:password@host:3306/database
DATABASE_URL=mysql://root:password@localhost:3306/restaurant_map

# AWS S3
AWS_REGION=ap-northeast-1
AWS_S3_BUCKET=your-s3-bucket-name
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
# Optional: custom S3 endpoint (for MinIO/local testing)
# AWS_S3_ENDPOINT=

# Google Maps
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Security
CSRF_COOKIE_NAME=csrfToken
CSRF_COOKIE_SECRET=change-me-please